# ─── Google OAuth ───────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# See README.md "Google OAuth Setup" section for step-by-step instructions
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3456

# Public URL of THIS server (used for OAuth callback URL and token issuer)
# In dev: http://localhost:3456
# In prod: https://license.yourdomain.com
BASE_URL=http://localhost:3456

# Session secret (for the short-lived OAuth session only — not the JWT secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# ─── Stripe ───────────────────────────────────────────────────────────────────────
# Secret key from Stripe Dashboard → Developers → API keys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret from:
#   Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# OR from Stripe CLI: stripe listen --forward-to localhost:3456/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Price IDs from Stripe Dashboard → Product catalog → your product → Prices
# Create one recurring monthly price per tier; copy the price_XXXX ID here
STRIPE_PRICE_BASIC=price_your_basic_monthly_price_id
STRIPE_PRICE_PRO=price_your_pro_monthly_price_id

# Admin role allowlist (comma-separated email addresses)
ADMIN_EMAILS=admin@example.com
